# ─────────────────────────────────────────────────────────────────
# Cognitive Compliance — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=https://cognitivecompliance.co.uk

# Email — Resend (https://resend.com)
# Create a free account, verify your domain, and paste your API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=hello@cognitivecompliance.co.uk
CONTACT_FROM_EMAIL=no-reply@cognitivecompliance.co.uk

# Analytics — Plausible (https://plausible.io)  [optional]
# Set to enable the Plausible snippet in the layout.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=cognitivecompliance.co.uk

# Analytics — PostHog (https://posthog.com)  [optional]
# Set BOTH to enable PostHog.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
